<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Study Timer Widget</title>
    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --accent-start: #3b82f6;
            --accent-end: #1d4ed8;
            --stop-start: #ef4444;
            --stop-end: #b91c1c;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
        }

        body {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            background-color: var(--bg-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            color: var(--text-main);
        }

        /* Widget Container shaped like a phone home-screen card */
        .widget-card {
            background-color: var(--card-bg);
            width: 320px;
            padding: 24px;
            border-radius: 28px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.2);
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .widget-title {
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            margin-bottom: 16px;
            font-weight: 600;
        }

        /* Digital Display */
        .timer-display {
            font-size: 3rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            margin-bottom: 24px;
            letter-spacing: -0.02em;
        }

        /* The Massive Main Button */
        .main-btn {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            border: none;
            cursor: pointer;
            outline: none;
            font-size: 1.1rem;
            font-weight: 700;
            color: white;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.4);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: inline-flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 24px;
        }

        /* Button States */
        .btn-study {
            background: linear-gradient(135deg, var(--accent-start), var(--accent-end));
        }

        .btn-study:hover {
            transform: scale(1.03);
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.4);
        }

        .btn-stop {
            background: linear-gradient(135deg, var(--stop-start), var(--stop-end));
            animation: pulse 2s infinite;
        }

        .btn-stop:hover {
            transform: scale(1.03);
            box-shadow: 0 0 20px rgba(239, 68, 68, 0.4);
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
            70% { box-shadow: 0 0 0 15px rgba(239, 68, 68, 0); }
            100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }

        /* Footer Controls */
        .control-footer {
            display: flex;
            justify-content: space-around;
            align-items: center;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 16px;
        }

        .status-text {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .reset-btn {
            background: transparent;
            border: 1px solid var(--text-muted);
            color: var(--text-muted);
            padding: 6px 12px;
            border-radius: 12px;
            font-size: 0.75rem;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.2s;
        }

        .reset-btn:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-main);
            border-color: var(--text-main);
        }
    </style>
</head>
<body>

    <div class="widget-card">
        <div class="widget-title" id="status-label">Ready to Focus</div>
        
        <div class="timer-display" id="display">00:00:00</div>
        
        <button class="main-btn btn-study" id="toggle-btn">Study</button>
        
        <div class="control-footer">
            <span class="status-text" id="session-count">Sessions: 0</span>
            <button class="reset-btn" id="reset-btn">Reset</button>
        </div>
    </div>

    <script>
        let startTime = 0;
        let elapsedTime = 0;
        let timerInterval;
        let isRunning = false;
        let completedSessions = 0;

        const displayEl = document.getElementById('display');
        const toggleBtn = document.getElementById('toggle-btn');
        const statusLabel = document.getElementById('status-label');
        const sessionCountEl = document.getElementById('session-count');
        const resetBtn = document.getElementById('reset-btn');

        function formatTime(ms) {
            let totalSeconds = Math.floor(ms / 1000);
            let hours = Math.floor(totalSeconds / 3600);
            let minutes = Math.floor((totalSeconds % 3600) / 60);
            let seconds = totalSeconds % 60;

            return (
                (hours < 10 ? "0" + hours : hours) + ":" +
                (minutes < 10 ? "0" + minutes : minutes) + ":" +
                (seconds < 10 ? "0" + seconds : seconds)
            );
        }

        function startTimer() {
            startTime = Date.now() - elapsedTime;
            timerInterval = setInterval(() => {
                elapsedTime = Date.now() - startTime;
                displayEl.textContent = formatTime(elapsedTime);
            }, 1000);
            
            toggleBtn.textContent = "Stop";
            toggleBtn.className = "main-btn btn-stop";
            statusLabel.textContent = "Studying...";
            isRunning = true;
        }

        function stopTimer() {
            clearInterval(timerInterval);
            toggleBtn.textContent = "Study";
            toggleBtn.className = "main-btn btn-study";
            statusLabel.textContent = "Paused";
            isRunning = false;

            // Increment session tally if studied for at least a few seconds
            if (elapsedTime > 5000) {
                completedSessions++;
                sessionCountEl.textContent = `Sessions: ${completedSessions}`;
            }
        }

        toggleBtn.addEventListener('click', () => {
            if (!isRunning) {
                startTimer();
            } else {
                stopTimer();
            }
        });

        resetBtn.addEventListener('click', () => {
            clearInterval(timerInterval);
            elapsedTime = 0;
            displayEl.textContent = "00:00:00";
            toggleBtn.textContent = "Study";
            toggleBtn.className = "main-btn btn-study";
            statusLabel.textContent = "Ready to Focus";
            isRunning = false;
        });
    </script>
</body>
</html>
